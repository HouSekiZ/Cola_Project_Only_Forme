# Patient Assist – Environment Variables
# Copy this to .env and edit as needed

# Flask
SECRET_KEY=change-me-in-production
FLASK_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=5000

# Camera
CAMERA_INDEX=0
FRAME_WIDTH=640
FRAME_HEIGHT=480

# Detection thresholds
EAR_THRESHOLD=0.22
GAZE_THRESHOLD=45

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/patient_assist.log
